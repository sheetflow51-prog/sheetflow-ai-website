# SheetFlow AI — Environment Variables
# Copy to .env.local for local development.
# In production: configure in Vercel → Settings → Environment Variables.
# Never commit .env.local to version control.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Canonical site URL (no trailing slash).
# Used by: OG images, sitemap, JSON-LD, canonical tags.
NEXT_PUBLIC_SITE_URL=https://sheetflow.ai

# ─────────────────────────────────────────────────────────────────────────────
# SPLINE 3D SCENES — all optional (empty string = R3F AICore fallback)
# ─────────────────────────────────────────────────────────────────────────────
# URL format: https://prod.spline.design/<id>/scene.splinecode
# Obtain from: Spline → File → Export → Code Export → React
# Staging URLs (spline.design/preview/*) NOT allowed in production env.
# Promotion order: Dashboard → Workflow → Hero → CTA (FINAL_EXECUTION_LAYER §5.3)
NEXT_PUBLIC_SPLINE_SCENE_HERO=
NEXT_PUBLIC_SPLINE_SCENE_WORKFLOW=
NEXT_PUBLIC_SPLINE_SCENE_DASHBOARD=
NEXT_PUBLIC_SPLINE_SCENE_CTA=

# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS — all optional, zero-config when packages are installed
# ─────────────────────────────────────────────────────────────────────────────
# Vercel Analytics: enable in Vercel Dashboard → Project → Analytics
# No env var needed — activated by <Analytics /> in layout.tsx.

# Plausible (privacy-first alternative):
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sheetflow.ai

# ─────────────────────────────────────────────────────────────────────────────
# FUTURE — not yet implemented
# ─────────────────────────────────────────────────────────────────────────────
# Inquiry form backend (server-only, never NEXT_PUBLIC_*)
# RESEND_API_KEY=
# INQUIRY_FROM_EMAIL=hello@sheetflow.ai
# INQUIRY_TO_EMAIL=founders@sheetflow.ai
