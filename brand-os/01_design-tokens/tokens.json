{
  "$schema": "https://schemas.sheetflow.ai/brand-tokens/v1.json",
  "$meta": {
    "name": "SheetFlow Brand Tokens",
    "version": "1.0.0",
    "description": "Platform-agnostic design tokens. Source of truth: tokens.ts",
    "consumers": ["web", "mobile", "figma", "after-effects", "pdf"]
  },
  "color": {
    "void": "#060608",
    "surface": { "0": "#060608", "1": "#0A0B0F", "2": "#0F1117", "3": "#141720", "4": "#1A1F2E" },
    "ink": {
      "50": "#FFFFFF", "100": "#F5F7FA", "200": "#D6DCE8", "300": "#A0A8BC",
      "400": "#6B7490", "500": "#3D4460", "600": "#2A3045", "700": "#1E2435",
      "800": "#141720", "900": "#0F1117", "950": "#0A0B0F"
    },
    "accent": {
      "default": "#6366F1", "bright": "#818CF8", "light": "#A5B4FC",
      "deep": "#4F46E5", "glow": "rgba(99,102,241,0.15)"
    },
    "violet": { "default": "#8B5CF6", "bright": "#A78BFA", "deep": "#7C3AED" },
    "cyan": { "default": "#06B6D4", "bright": "#22D3EE" },
    "signal": {
      "success": "#10B981", "warning": "#F59E0B",
      "danger": "#F43F5E", "info": "#06B6D4"
    }
  },
  "duration": {
    "micro": 100, "fast": 180, "base": 250, "reveal": 600,
    "scene": 900, "cinematic": 1200, "cinematicMax": 1600,
    "stagger": 80, "pulseLive": 2000, "breath": 6000
  },
  "easing": {
    "cinematic": [0.16, 1, 0.3, 1],
    "spring": [0.34, 1.56, 0.64, 1],
    "intelligence": [0.4, 0.0, 0.2, 1.0]
  },
  "space": {
    "0_5": 2, "1": 4, "2": 8, "3": 12, "4": 16, "6": 24, "8": 32,
    "12": 48, "16": 64, "24": 96, "32": 128, "48": 192, "64": 256
  },
  "layout": {
    "sectionPaddingMin": 80, "sectionPaddingMax": 160,
    "headlineIsolationFactor": 2, "cardGap": 12,
    "headlineToSub": 28, "subToCta": 40,
    "containerMaxWidth": 1280
  },
  "atmosphere": {
    "aurora": { "keyAlpha": 0.18, "fillAlpha": 0.12, "rimAlpha": 0.06, "cursorLerp": 0.04 },
    "grain": { "alpha": 0.035, "blendMode": "overlay" },
    "hum": { "pulseScaleMin": 0.85, "pulseScaleMax": 1.0, "breathAmplitude": 0.02 }
  },
  "bracket": {
    "size": { "sm": 12, "md": 16, "lg": 24, "xl": 32 },
    "thickness": { "sm": 1, "md": 1, "lg": 2, "xl": 2 },
    "inset": 8,
    "color": "rgba(99,102,241,0.65)"
  },
  "scanLine": { "repeat": 4, "lineWidth": 1, "alpha": 0.04 }
}
